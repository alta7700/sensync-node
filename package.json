{
  "name": "sensync2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:fake",
    "dev:fake": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:fake\"",
    "dev:fake-hdf5-simulation": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:fake-hdf5-simulation\"",
    "dev:runtime": "npm run dev:runtime:fake",
    "dev:runtime:fake": "SENSYNC2_PROFILE=fake npm --workspace @sensync2/runtime run dev",
    "dev:runtime:fake-hdf5-simulation": "SENSYNC2_PROFILE=fake-hdf5-simulation npm --workspace @sensync2/runtime run dev",
    "dev:client": "npm --workspace @sensync2/client run dev",
    "dev:desktop": "npm run dev:desktop:fake",
    "dev:desktop:fake": "SENSYNC2_PROFILE=fake npm --workspace @sensync2/desktop run dev",
    "dev:desktop:fake-hdf5-simulation": "SENSYNC2_PROFILE=fake-hdf5-simulation npm --workspace @sensync2/desktop run dev",
    "smoke:hdf5-recorder": "tsx ./scripts/smoke_hdf5_recorder.ts",
    "smoke:fake-hdf5-simulation": "tsx ./scripts/smoke_fake_hdf5_simulation.ts",
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@types/node": "^24.6.0",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
