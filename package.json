{
  "name": "sensync2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:fake",
    "dev:fake": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:fake\"",
    "dev:fake-hdf5-simulation": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:fake-hdf5-simulation\"",
    "dev:pedaling-emg-test": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:pedaling-emg-test\"",
    "dev:pedaling-emg-replay": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:pedaling-emg-replay\"",
    "dev:pedaling-emg-viewer": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:pedaling-emg-viewer\"",
    "dev:veloerg": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:veloerg\"",
    "dev:veloerg-replay": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:veloerg-replay\"",
    "dev:veloerg-viewer": "concurrently -k -n CLIENT,DESKTOP \"npm run dev:client\" \"npm run dev:desktop:veloerg-viewer\"",
    "dev:runtime": "npm run dev:runtime:fake",
    "dev:runtime:fake": "SENSYNC2_PROFILE=fake npm --workspace @sensync2/runtime run dev",
    "dev:runtime:fake-hdf5-simulation": "SENSYNC2_PROFILE=fake-hdf5-simulation npm --workspace @sensync2/runtime run dev",
    "dev:runtime:pedaling-emg-test": "SENSYNC2_PROFILE=pedaling-emg-test npm --workspace @sensync2/runtime run dev",
    "dev:runtime:pedaling-emg-replay": "SENSYNC2_PROFILE=pedaling-emg-replay npm --workspace @sensync2/runtime run dev",
    "dev:runtime:pedaling-emg-viewer": "SENSYNC2_PROFILE=pedaling-emg-viewer npm --workspace @sensync2/runtime run dev",
    "dev:runtime:veloerg": "SENSYNC2_PROFILE=veloerg npm --workspace @sensync2/runtime run dev",
    "dev:runtime:veloerg-replay": "SENSYNC2_PROFILE=veloerg-replay npm --workspace @sensync2/runtime run dev",
    "dev:runtime:veloerg-viewer": "SENSYNC2_PROFILE=veloerg-viewer npm --workspace @sensync2/runtime run dev",
    "dev:client": "npm --workspace @sensync2/client run dev",
    "dev:desktop": "npm run dev:desktop:fake",
    "dev:desktop:fake": "SENSYNC2_PROFILE=fake npm --workspace @sensync2/desktop run dev",
    "dev:desktop:fake-hdf5-simulation": "SENSYNC2_PROFILE=fake-hdf5-simulation npm --workspace @sensync2/desktop run dev",
    "dev:desktop:pedaling-emg-test": "SENSYNC2_PROFILE=pedaling-emg-test npm --workspace @sensync2/desktop run dev",
    "dev:desktop:pedaling-emg-replay": "SENSYNC2_PROFILE=pedaling-emg-replay npm --workspace @sensync2/desktop run dev",
    "dev:desktop:pedaling-emg-viewer": "SENSYNC2_PROFILE=pedaling-emg-viewer npm --workspace @sensync2/desktop run dev",
    "dev:desktop:veloerg": "SENSYNC2_PROFILE=veloerg npm --workspace @sensync2/desktop run dev",
    "dev:desktop:veloerg-replay": "SENSYNC2_PROFILE=veloerg-replay npm --workspace @sensync2/desktop run dev",
    "dev:desktop:veloerg-viewer": "SENSYNC2_PROFILE=veloerg-viewer npm --workspace @sensync2/desktop run dev",
    "generate:runtime-event-map": "tsx ./scripts/generate_runtime_event_map.ts",
    "generate:compute-proto": "./scripts/generate_compute_proto.sh",
    "smoke": "npm run smoke:fake-profile && npm run smoke:hdf5-recorder && npm run smoke:fake-hdf5-simulation",
    "smoke:fake-profile": "tsx ./scripts/smoke_fake_profile.ts",
    "smoke:hdf5-recorder": "tsx ./scripts/smoke_hdf5_recorder.ts",
    "smoke:fake-hdf5-simulation": "tsx ./scripts/smoke_fake_hdf5_simulation.ts",
    "build": "npm run --workspaces build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run --workspaces test",
    "coverage": "npm run --workspaces test -- --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=text-summary --coverage.reporter=html --coverage.reporter=json-summary",
    "verify": "npm run lint && npm run test && npm run build && npm run smoke"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@esbuild/darwin-arm64": "^0.27.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "tsx": "^4.20.6",
    "ts-proto": "^2.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  }
}
